<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.module"> <!-- Or whatever your namespace is -->

    <application
        android:allowBackup="true"
        android:label="My Redirect Module"
        android:supportsRtl="true">

        <!-- THESE THREE TAGS ARE REQUIRED FOR LSPOSED TO DETECT THE MODULE -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="Redirects specific file paths for apps." />
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

    </application>
</manifest>

